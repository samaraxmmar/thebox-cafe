# ──────────────────────────────────────────────
# THE BOX — Variables d'environnement (TEMPLATE)
# Copie ce fichier en .env et remplis les vraies valeurs.
# NE JAMAIS mettre de vrais secrets ici (ce fichier est committé).
# ──────────────────────────────────────────────

# Mode (production = logs JSON, perfs max)
NODE_ENV=production

# Réseau
PORT=3001
# 127.0.0.1 = local uniquement · 0.0.0.0 = accessible sur le LAN (postes serveurs)
HOST=0.0.0.0

# Logs : debug | info | warn | error
LOG_LEVEL=info

# Sessions
SESSION_TTL_HOURS=12
# Secret de signature des cookies (si vide, généré et persisté au 1er démarrage)
SESSION_SECRET=

# ──────────────────────────────────────────────
# Supabase (obligatoire)
# Dashboard → Settings → API
# ──────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clé pour le serveur. En PRODUCTION, utilise la service_role key
# (Settings → API → service_role) — elle bypass RLS et reste côté serveur.
SUPABASE_SERVICE_KEY=

# anon key (fallback si service_role absente)
SUPABASE_KEY=

# ──────────────────────────────────────────────
# WhatsApp (optionnel — laisser vide pour désactiver)
# Numéro avec indicatif pays, sans + ni espaces. Ex Tunisie : 216XXXXXXXX
# ──────────────────────────────────────────────
WHATSAPP_NUMBER=
